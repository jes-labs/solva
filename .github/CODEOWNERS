# Code ownership for Solva. A listed owner is requested for review on changes
# to their paths. Replace the placeholder owner with the real per-tier owners
# once the team is mapped. Keep the most specific rule last.

# Default owner for everything not matched below.
*                       @Signor1

# Cryptography and on-chain tiers. These need a reviewer fluent in the circuit
# and contract, since a change here can break the proof.
/circuits/              @Signor1
/contracts/             @Signor1
/services/prover/       @Signor1
/proto/                 @Signor1

# Backend orchestration and the sandbox.
/services/orchestrator/ @Signor1
/services/sandbox/      @Signor1

# Web, oracle, SDK, and shared packages.
/apps/                  @Signor1
/services/oracle/       @Signor1
/packages/              @Signor1
