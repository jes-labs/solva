{
  "name": "@solva/config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript, ESLint, Tailwind, and Prettier presets for the Solva monorepo",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./eslint.preset.js": "./eslint.preset.js",
    "./tailwind.preset.js": "./tailwind.preset.js",
    "./prettier.config.js": "./prettier.config.js"
  },
  "files": [
    "tsconfig.base.json",
    "eslint.preset.js",
    "tailwind.preset.js",
    "prettier.config.js"
  ],
  "scripts": {
    "lint": "echo \"@solva/config: no sources to lint\"",
    "typecheck": "echo \"@solva/config: presets only, nothing to typecheck\""
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@eslint/js": "^9.39.0",
    "typescript-eslint": "^8.61.0",
    "eslint-config-prettier": "^9.1.0"
  }
}
