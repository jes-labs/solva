{
  "name": "@solva/contract-bindings",
  "version": "0.1.0",
  "private": true,
  "description": "Wrapper around the generated Soroban TypeScript bindings for proof-registry",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p src/generated && tsup",
    "build:generated": "tsc -p src/generated",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "typecheck": "tsc -p src/generated && tsc --noEmit"
  },
  "dependencies": {
    "@solva/shared-types": "workspace:*",
    "buffer": "^6.0.3"
  },
  "peerDependencies": {
    "@stellar/stellar-sdk": "^16.0.0"
  },
  "devDependencies": {
    "@solva/config": "workspace:*",
    "@stellar/stellar-sdk": "^16.0.0",
    "eslint": "^9.39.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0"
  }
}
