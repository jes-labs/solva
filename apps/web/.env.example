# The orchestrator REST API. The web resolves an institution to its own
# proof-registry contract through this, then reads that contract (#129/#130).
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8080

# Stellar network the institutions' contracts live on: testnet, mainnet, or local.
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Soroban RPC and network passphrase for the on-chain reads.
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
